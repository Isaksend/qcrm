@startuml component_diagram

skinparam shadowing false
skinparam actorStyle awesome
skinparam usecase {
  BackgroundColor #F8FAFC
  BorderColor #64748B
}
skinparam packageStyle rectangle

package "Client Tier" {
  [Vue.js SPA] as VUE
  [Vuetify UI] as UI
  VUE -- UI
}

package "Application Tier (FastAPI Monolith)" {
  [Nginx \n(Reverse Proxy + TLS)] as NGINX
  [Uvicorn (ASGI)] as UVICORN
  package "FastAPI Routers" {
    [/auth]       as AUTH
    [/users]      as USERS
    [/contacts]   as CONTACTS
    [/companies]  as COMPANIES
    [/deals]      as DEALS
    [/activities] as ACTIVITIES
    [/chat]       as CHAT
    [/ai]         as AI
    [/analytics]  as ANALYTICS
    [/reports]    as REPORTS
  }
  together {
  [SQLAlchemy \n(Async ORM)] as ORM
  [Alembic \n(Database migrations)] as MIGR	
  }
  NGINX   --> UVICORN
  UVICORN --> AUTH
  UVICORN --> USERS
  UVICORN --> CONTACTS
  UVICORN --> COMPANIES
  UVICORN --> DEALS
  UVICORN --> ACTIVITIES
  UVICORN --> CHAT
  UVICORN --> AI
  UVICORN --> ANALYTICS
  UVICORN --> REPORTS
  AUTH       --> ORM
  CONTACTS   --> ORM
  DEALS      --> ORM
  ACTIVITIES --> ORM
  REPORTS    --> ORM
}

together {
package "ML Artefacts (disk)" {
  [lead_scoring_model.pkl]  as LS
  [churn_prediction_model.pkl]  as CM
}

package "Data Tier" {
  database "PostgreSQL" as PG
}

}
VUE  --> NGINX : HTTPS/REST JSON
ORM  --> PG
MIGR --> PG
AI   --> LS
AI   --> CM
@enduml

